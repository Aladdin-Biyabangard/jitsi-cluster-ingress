# ============================================================
# jitsi-deploy — minimum .env, sonra: ./deploy.sh
# ============================================================

# --- MƏCBURİ ---
GCP_PROJECT_ID=jitsi-cluster-501917
DOMAIN=meet.ingress.academy
ADMIN_EMAIL=aladdin19.11.21@gmail.com

# --- Bunny Stream (Ingress portal ilə eyni) ---
BUNNY_LIBRARY_ID=692053
BUNNY_API_KEY=ff237830-8b56-488d-bb8882360f56-6077-4951
# BUNNY_CDN_HOSTNAME=vz-xxxx.b-cdn.net

# --- GCP (default kifayətdir) ---
GCP_REGION=europe-west1
GCP_ZONE=europe-west1-b
GCP_NETWORK=default

# --- Schedule (VM start/stop, xərc qənaəti) ---
# Test müddətində false saxla — VM-lər 24/7 aktiv qalır.
# Test bitəndən sonra true et və Cloud Shell-də job-ları resume et:
#   gcloud scheduler jobs resume jitsi-start-meet-control --location=europe-west1 --project=jitsi122
#   (və ya bütün jitsi-* job-lar üçün eyni)
ENABLE_SCHEDULE=false
SCHEDULE_START_UTC=03:30
SCHEDULE_STOP_UTC=06:05
SCHEDULE_TIMEZONE=UTC

# --- Recording capacity (adaptiv) ---
# Eyni anda neçə recording? → deploy özü VM/proses sayını seçir
# Default: 2 recorder VM × 5 Jibri proses = 10 paralel (1 VM ≠ 1 record)
CONCURRENT_RECORDINGS=10
# İstəyə görə əl ilə:
# RECORDER_COUNT=2
# JIBRI_PER_VM=5

# control(4) + jvb(8) + 2×recorder(8) = 28 vCPU (32 limitə sığır)
CONTROL_MACHINE_TYPE=e2-standard-4
JVB_MACHINE_TYPE=e2-standard-8
JIBRI_MACHINE_TYPE=e2-standard-8
CONTROL_DISK_GB=50
JVB_DISK_GB=50
JIBRI_DISK_GB=80

# Daha güclü recorder-lər (quota artımı lazım ola bilər):
# DEPLOY_PROFILE=full

# --- Cloudflare DNS (optional) ---
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ZONE_ID=
# CLOUDFLARE_RECORD_NAME=meet.example.com

# --- SSH (boş = avtomatik ./secrets/deploy_key) ---
# SSH_PUBLIC_KEY_PATH=
